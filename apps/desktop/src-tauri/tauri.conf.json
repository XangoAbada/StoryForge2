{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoryForge2",
  "version": "0.1.0",
  "identifier": "dev.storyforge2.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StoryForge2",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/covers/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
